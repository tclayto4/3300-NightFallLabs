Cart.html
    <body>
    <main class="page">
        <section class="content">
            <h1>Your Cart</h1>
            <!--container where items are dynamically rendered-->
            <div id="cartContainer">
                <p>Your cart items are located here</p>
            </div>
            <!--displays calculated totals-->
            <div id="cartTotals">
                <p><strong>Subtotal:</strong> <span id="subtotalValue">$0.00</span></p>
                <p><strong>Tax:</strong> <span id="taxValue">$0.00</span></p>
                <p><strong>Delivery Fee:</strong> <span id="deliveryFeeValue">$0.00</span></p>
                <p><strong>Service Fee:</strong> <span id="serviceFeeValue">$0.00</span></p>
                <p><strong>Tip:</strong> <span id="tipValue">$0.00</span></p>
                <h3>Total: <span id="totalValue">$0.00</span></h3>
            </div>

            <!--Navigation buttons-->
            <div class="item-actions">
                <a href="index.html">Continue Shopping</a>
                <a href="checkout.html">Proceed to Checkout</a>
            </div>
        </section>
    </main>
    <!--loads cart functionality  -->
    <script src="cart.js"></script>
</body>
</html>
Checkout.html
<body>
    <main class="page">
        <section class="content">
            <h1>Checkout</h1>
            <!--form to collect order info and customer info-->
            <form id="checkoutForm">
                <!--pickup or delivery selection-->
                <label for="orderType">Order Type</label>
                <select id="orderType" required>
                    <option value="Delivery">Delivery</option>
                    <option value="Pickup">Pickup</option>
                </select>
                <!--delivery address required if delivery is selected-->
                <div id="deliveryAddressGroup">
                    <label for="deliveryAddress">Delivery Address</label>
                    <input type="text" id="deliveryAddress" />
                </div>
                <!--customer info and payment info-->
                <label for="contactEmail">Email</label>
                <input type="email" id="contactEmail" required />
                <label for="cardholderName">Cardholder Name</label>
                <input type="text" id="cardholderName" required />
                <label for="cardNumber">Card Number</label>
                <input type="text" id="cardNumber" required />
                <!--tip option-->
                <label for="tipAmount">Tip</label>
                <input type="number" id="tipAmount" min="0" step="0.01" value="0" />
                <!--places order-->
                <button type="submit">Place Order</button>
            </form>
            <!--order confirmation success/failure message-->
           <p id="checkoutConfirmation"></p>
        </section>
    </main>
    <script src="checkout.js"></script>
</body>
</html>
