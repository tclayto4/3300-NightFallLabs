            <main class="page">
                <!--side bar for filtering items on menu-->
                <aside class="filters">
                    <h2>Filters</h2>
                    <!--Food Filter-->
                    <label for="categoryFilter">Category</label>
                    <select id="categoryFilter">
                        <option value="All">All</option>
                        <option value="Burgers">Burgers</option>
                        <option value="Wraps">Wraps</option>
                        <option value="Salads">Salads</option>
                    </select>
                    <!--Allergen Filter-->
                    <h3>Exclude Allergens</h3>
                    <div class="checkbox-group">
                        <label><input type="checkbox" value="Dairy" class="allergenCheckbox">Dairy</label>
                        <label><input type="checkbox" value="Gluten" class="allergenCheckbox">Gluten</label>
                        <label><input type="checkbox" value="Soy" class="allergenCheckbox">Soy</label>
                        <label><input type="checkbox" value="Nuts" class="allergenCheckbox">Nuts</label>
                    </div>
                    <!--Dietary Restrictions Filter-->
                    <h3>Dietary Restrictions</h3>
                    <div class="checkbox-group">
                        <label><input type="checkbox" value="Vegetarian" class="dietaryCheckbox">Vegetarian</label>
                        <label><input type="checkbox" value="Vegan" class="dietaryCheckbox">Vegan</label>
                        <label><input type="checkbox" value="Gluten Free" class="dietaryCheckbox">Gluten Free</label>
                    </div>
                    <!--Applies filter by calling js function-->
                    <button id="applyFilterButton">Apply Filters</button>
                    <!--resets applied filters and reloads page-->
                    <button id="resetFiltersButton" class="secondary-button">Reset</button>
                </aside>

            <section class="content">
                <h1>Menu</h1>
                <div id="menuContainer"></div>
            </section>
            </main>

